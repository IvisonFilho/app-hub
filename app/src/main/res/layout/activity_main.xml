<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32.dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="App Hub"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#333333" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Escolha um aplicativo"
        android:textSize="16sp"
        android:layout_marginTop="8dp"
        android:textColor="#666666" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="48dp" />

    <Button
        android:id="@+id/btnBasquete"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Placar de Basquete"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnCalculadora"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Calculadora Científica"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnNotas"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Bloco de Notas"
        android:textAllCaps="false"
        android:textSize="16sp" />

</LinearLayout>