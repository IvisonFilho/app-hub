<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_home"
            android:contentDescription="Voltar para tela inicial"
            app:tint="?attr/colorPrimary" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchTema"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:thumbIcon="@drawable/seletor_icone_tema" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtResultado"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bordas_arredondadas_visor_calculadora"
        android:gravity="bottom|end"
        android:minHeight="160dp"
        android:padding="20dp"
        android:text="0"
        android:textColor="?attr/colorOnSurface"
        android:textSize="48sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout" />

    <GridLayout
        android:id="@+id/gridButtons"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alignmentMode="alignMargins"
        android:columnCount="4"
        android:rowCount="6"
        android:useDefaultMargins="false"
        android:layout_marginTop="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtResultado">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLog"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="0" android:layout_column="0"
            android:text="log" app:backgroundTint="?attr/colorTertiaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSin"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="0" android:layout_column="1"
            android:text="sin" app:backgroundTint="?attr/colorTertiaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCos"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="0" android:layout_column="2"
            android:text="cos" app:backgroundTint="?attr/colorTertiaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClear"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="0" android:layout_column="3"
            android:text="C" app:backgroundTint="?attr/colorErrorContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuadrado"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="1" android:layout_column="0"
            android:text="x²" app:backgroundTint="?attr/colorTertiaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRaiz"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="1" android:layout_column="1"
            android:text="√" app:backgroundTint="?attr/colorTertiaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPorcentagem"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="1" android:layout_column="2"
            android:text="%" app:backgroundTint="?attr/colorTertiaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDividir"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="1" android:layout_column="3"
            android:text="÷" app:backgroundTint="?attr/colorTertiaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn7"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="2" android:layout_column="0"
            android:text="7" app:backgroundTint="?attr/colorSecondaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn8"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="2" android:layout_column="1"
            android:text="8" app:backgroundTint="?attr/colorSecondaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn9"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="2" android:layout_column="2"
            android:text="9" app:backgroundTint="?attr/colorSecondaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMultiplicar"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="2" android:layout_column="3"
            android:text="×" app:backgroundTint="?attr/colorTertiaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn4"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="3" android:layout_column="0"
            android:text="4" app:backgroundTint="?attr/colorSecondaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn5"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="3" android:layout_column="1"
            android:text="5" app:backgroundTint="?attr/colorSecondaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn6"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="3" android:layout_column="2"
            android:text="6" app:backgroundTint="?attr/colorSecondaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubtrair"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="3" android:layout_column="3"
            android:text="-" app:backgroundTint="?attr/colorTertiaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn1"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="4" android:layout_column="0"
            android:text="1" app:backgroundTint="?attr/colorSecondaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn2"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="4" android:layout_column="1"
            android:text="2" app:backgroundTint="?attr/colorSecondaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn3"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="4" android:layout_column="2"
            android:text="3" app:backgroundTint="?attr/colorSecondaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSomar"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="4" android:layout_column="3"
            android:text="+" app:backgroundTint="?attr/colorTertiaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn0"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="5" android:layout_column="0"
            android:text="0" app:backgroundTint="?attr/colorSecondaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPonto"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="5" android:layout_column="1"
            android:text="." app:backgroundTint="?attr/colorSecondaryContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackspace"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="5" android:layout_column="2"
            android:text="⌫" app:backgroundTint="?attr/colorErrorContainer"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnIgual"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="6dp"
            android:layout_row="5" android:layout_column="3"
            android:text="="
            android:textColor="@android:color/white"
            app:backgroundTint="?attr/colorPrimary"
            app:shapeAppearanceOverlay="@style/BotaoQuadrado" />

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>